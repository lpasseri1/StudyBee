# https://vercel.com/docs/storage/vercel-postgres
POSTGRES_URL=

# Supabase project settings -> API
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-only, never expose to the client.
# Used by the delete-account route to remove the auth user via the admin API.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: music playback integrations for Focus Study mode.
# Leave blank to keep those connect buttons disabled.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
APPLE_MUSIC_TEAM_ID=
APPLE_MUSIC_KEY_ID=
APPLE_MUSIC_PRIVATE_KEY=
